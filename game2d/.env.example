PORT=3001
POSTGRES_URL=postgresql://game2d:game2d@127.0.0.1:5432/game2d
CLIENT_ORIGIN=http://localhost:5175

REDIS_URL=redis://127.0.0.1:6379

# Dev-only fallback exists in code, but always set a real secret in production.
JWT_SECRET=dev-only-change-me-game2d
JWT_EXPIRES_IN=12h
BCRYPT_SALT_ROUNDS=12

# Socket.io heartbeat (ping/pong) — how often the server pings, and how long
# it waits for a pong before considering the connection dead.
HEARTBEAT_PING_INTERVAL_MS=10000
HEARTBEAT_PING_TIMEOUT_MS=5000

# Per-IP connection rate limiting (Socket.io handshakes).
SOCKET_CONN_RATE_LIMIT_MAX=20
SOCKET_CONN_RATE_LIMIT_WINDOW_MS=60000

# Per-socket move-command rate limiting (token bucket).
COMMAND_RATE_LIMIT_MAX=10
COMMAND_RATE_LIMIT_REFILL_PER_SEC=10

VITE_SERVER_URL=http://localhost:3001
