{
  "name": "text-arena-mmo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "concurrently -n SERVER,CLIENT -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "nest start --watch",
    "dev:client": "vite",
    "build:client": "vite build",
    "build:server": "nest build",
    "start": "npm run build:server && node dist/server/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "@nestjs/common": "^10.4.1",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mongoose": "^10.0.10",
    "@nestjs/platform-fastify": "^10.4.1",
    "@nestjs/platform-socket.io": "^10.4.1",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/websockets": "^10.4.1",
    "bcryptjs": "^2.4.3",
    "mongoose": "^8.5.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ioredis": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.13",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "typescript": "^5.5.4",
    "vite": "^5.3.5"
  }
}
