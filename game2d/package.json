{
  "name": "game2d",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Standalone goblin/skeleton roam-around game — Phaser client + its own NestJS backend (auth, sockets, database, rate limiting, redis), structured the same way as the root project's src/server, but scoped to only what this game actually needs (no combat/skills/equipment — that's the text game's domain).",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "npm run free-ports && concurrently -n SERVER,CLIENT -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "free-ports": "lsof -ti tcp:3001 | xargs kill -9 2>/dev/null; lsof -ti tcp:5173 | xargs kill -9 2>/dev/null; exit 0",
    "dev:server": "nest start --watch",
    "dev:client": "vite",
    "build:client": "vite build",
    "build:server": "nest build",
    "start": "npm run build:server && node dist/server/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "@nestjs/common": "^10.4.1",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-fastify": "^10.4.1",
    "@nestjs/platform-socket.io": "^10.4.1",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.4.1",
    "bcryptjs": "^2.4.3",
    "ioredis": "^5.4.1",
    "pg": "^8.12.0",
    "phaser": "^3.80.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "typeorm": "^0.3.20",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.13",
    "@types/pg": "^8.11.6",
    "concurrently": "^8.2.2",
    "typescript": "^5.5.4",
    "vite": "^5.3.5"
  }
}
