PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/text-arena
CLIENT_ORIGIN=http://localhost:5173

REDIS_URL=redis://127.0.0.1:6379

# Dev-only fallback exists in code, but always set a real secret in production.
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=12h
BCRYPT_SALT_ROUNDS=12

# Socket.io heartbeat (ping/pong) — how often the server pings, and how long
# it waits for a pong before considering the connection dead.
HEARTBEAT_PING_INTERVAL_MS=10000
HEARTBEAT_PING_TIMEOUT_MS=5000

# Per-IP connection rate limiting (Socket.io handshakes).
SOCKET_CONN_RATE_LIMIT_MAX=20
SOCKET_CONN_RATE_LIMIT_WINDOW_MS=60000

# Per-socket command rate limiting (token bucket).
COMMAND_RATE_LIMIT_MAX=10
COMMAND_RATE_LIMIT_REFILL_PER_SEC=10

# Players per world instance before a new one (and, past the first
# instance per map, a dedicated worker_thread) is spawned.
WORLD_CAPACITY=50

# Skeleton NPCs in the Labyrinth: how often each one takes a random step,
# and how often (if the population is below the max of 10) one more spawns.
SKELETON_WANDER_INTERVAL_MS=60000
SKELETON_RESPAWN_INTERVAL_MS=60000

VITE_SERVER_URL=http://localhost:3000
